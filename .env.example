#--- Common ---
# Web → Admin のキャッシュ再検証通知に使う共有シークレット。
# Admin から Web の /api/revalidate に POST する際の Bearer として利用します。
REVALIDATE_SECRET=your-secret-key-here

# JSONデータのルートディレクトリ。未設定時は各アプリのカレント直下(`../data`)を解決します。
# リポジトリ直下の `data/` をそのまま使う場合は未設定で構いません。
# DATA_DIR=/absolute/path/to/data

#--- ポート設定 ---
# 他の mirai-gikai 系プロジェクトと同時起動する場合にポートを変更してください。
WEB_PORT=3000
ADMIN_PORT=3001

#--- Web ---
# Basic認証をONにする場合は設定してください。
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=

#--- Admin ---
# Web サーバーの URL。Admin → Web 通知（revalidate）で使用します。
NEXT_PUBLIC_WEB_URL=http://localhost:3000

# AI情報収集・議案コンテンツ生成で使用する AI プロバイダ。
# 設定値:
#   "gemini"     ... Gemini CLI 経由（既定）。ローカルに gemini CLI が必要。
#   "gemini-api" ... Gemini API を直接呼び出し（推奨・無料枠で RPM/RPD が緩い）。
#                    CLI 不要。GOOGLE_AI_API_KEY のみで動作します。
#   "claude"     ... Claude CLI 経由。ローカルに claude CLI が必要。
AI_CLI_PROVIDER=gemini

# Gemini CLI のパス（省略時は PATH 上の "gemini" を使用。AI_CLI_PROVIDER=gemini のとき有効）。
GEMINI_CLI_PATH=

# Gemini で使用するモデル。
# - AI_CLI_PROVIDER=gemini     : 省略時 Gemini CLI 既定モデル (2.5 Pro)。無料枠では "gemini-2.5-flash" 推奨。
# - AI_CLI_PROVIDER=gemini-api : 省略時 "gemini-2.5-flash"（10 RPM / 250 RPD、多段リサーチに十分）。
#                                品質優先なら "gemini-2.5-pro" (5 RPM / 100 RPD)。
#                                "gemini-2.5-flash-lite" は軽量タスク向けで、本用途のような多段ウェブ調査では
#                                途中で諦めて空結果を返しがちなので非推奨。
# 例: GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODEL=

# Claude CLI のパス（省略時は PATH 上の "claude" を使用。AI_CLI_PROVIDER=claude のとき有効）。
CLAUDE_CLI_PATH=

# Google AI Studio の APIキー。
# - AI_CLI_PROVIDER=gemini-api : AI情報収集（議案収集・ステータスチェック）で使用。**必須**。
# - AI画像生成（サムネイル）を使う場合も同じキーで動作します。
# 取得: https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=
OPENAI_API_KEY=
# DALL-E モデル選択（dall-e-2 または dall-e-3、省略時は dall-e-3）
DALLE_MODEL=dall-e-3
