  "bill_contents": [
    {
      "id": "c9a25461-dc18-40ec-a5cc-238b1db34119",
      "bill_id": "5b5161a8-4613-4387-993b-55e994a66148",
      "difficulty_level": "normal",
      "title": "埼玉県の国民健康保険の予算案",
      "summary": "国民健康保険の運営に関する予算案です。今年度は保険料が実質約1万2,600円値上がりする予定で、新しい子育て支援のための費用も追加されるため、負担の増加について議論されました。",
      "content": "自営業の方や年金を受け取っている方などが入る「国民健康保険」の運営にかかる予算案です。医療費が増えていることや、新しい子育て支援の仕組みが始まることから、今年度は保険料（税）が1万2,600円ほど値上がりする見込みになっています。これについて、県民の負担が大きくなると心配する声も議会であがりました。",
      "created_at": "2026-04-28T15:32:28.646Z",
      "updated_at": "2026-04-28T16:16:44.000Z"
    },
    {
      "id": "1fd0f709-ee55-4da1-bbd5-8fb78f3e067a",
      "bill_id": "5b5161a8-4613-4387-993b-55e994a66148",
      "difficulty_level": "hard",
      "title": "令和8年度埼玉県国民健康保険事業特別会計予算",
      "summary": "埼玉県の国民健康保険事業の運営に関する予算案です。令和8年度は国民健康保険税の実質的な負担が約1万2,600円引き上げられる見込みであり、子育て支援金の負担増も含まれることから、県民への負担増を懸念する議論が行われました。",
      "content": "本議案は、埼玉県が市町村とともに共同運営する国民健康保険事業に関する特別会計予算案です。令和8年度予算では、国民健康保険税の必要額が1万2,621円引き上げられる見込みとなっているほか、国の子ども・子育て支援法改正に伴う支援金の負担増が含まれており、議会内では県民負担の増大を懸念する反対意見も出されました。\n\n## 参照\n- [障害者の移動する権利を侵害しかねない予算 - 日本共産党埼玉県議会議員団](https://www.jcp-saitama-pref.jp/assembly-report/6419)",
      "created_at": "2026-04-28T15:32:28.646Z",
      "updated_at": "2026-04-28T16:16:44.000Z"
    }
  ],
