  "bill_contents": [
    {
      "id": "e227818a-730e-409e-bc06-f606a62cb652",
      "bill_id": "d2193a40-7d0a-4ee6-9694-3f79d97f3a15",
      "difficulty_level": "normal",
      "title": "市町村をサポートするための予算案",
      "summary": "県内の各市町村のまちづくりや財政を県が応援するための予算案で、今年度は約137億円が計上されています。",
      "content": "埼玉県内の市や町、村がまちづくりをしやすくなるよう、県がお金を貸したり交付したりしてサポートするための予算案です。令和8年度は約137億円が使われます。",
      "created_at": "2026-04-28T15:32:28.646Z",
      "updated_at": "2026-04-28T16:16:44.000Z"
    },
    {
      "id": "da0f5a21-68a1-47ed-82c6-ff6d94339447",
      "bill_id": "d2193a40-7d0a-4ee6-9694-3f79d97f3a15",
      "difficulty_level": "hard",
      "title": "令和8年度埼玉県市町村振興事業特別会計予算",
      "summary": "県内市町村の財政や事業をバックアップするための特別会計予算案です。令和8年度は137億5,030万3千円の予算が組まれました。",
      "content": "本議案は、県内の市町村の財政基盤強化や事業推進を支援するための特別会計予算案です。令和8年度の歳入歳出予算は137億5,030万3千円となっており、市町村への貸付金や交付金事業等に充てられます。\n\n## 参照\n- [令和8年2月定例会 議案一覧 - 埼玉県議会](https://www.pref.saitama.lg.jp/e1601/gikai-gaiyou/r0802/2.html)",
      "created_at": "2026-04-28T15:32:28.646Z",
      "updated_at": "2026-04-28T16:16:44.000Z"
    }
  ],
