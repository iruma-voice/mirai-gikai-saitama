    {
      "id": "38bbcb62-de31-4c5c-9e72-201defa96bc8",
      "bill_id": "54332449-f156-4206-88dc-86d37660d300",
      "difficulty_level": "normal",
      "title": "埼玉県証紙の管理にかかる予算案",
      "summary": "手数料の支払いに使う「埼玉県証紙」の発行や管理を行うための予算案で、総額は5,120万円です。",
      "content": "パスポートの申請や試験の手数料などを払うときに使う「埼玉県証紙」を作ったり、管理したりするための予算案です。令和8年度は総額5,120万円が計上されています。",
      "created_at": "2026-04-28T15:32:28.646Z",
      "updated_at": "2026-04-28T16:16:44.000Z"
    },
    {
      "id": "cc8833ee-a2e7-4b31-a655-e93b766cd95c",
      "bill_id": "54332449-f156-4206-88dc-86d37660d300",
      "difficulty_level": "hard",
      "title": "令和8年度埼玉県証紙特別会計予算",
      "summary": "手数料納付などに使われる埼玉県証紙の運用・管理を行う特別会計予算案です。令和8年度の予算総額は5,120万円となっています。",
      "content": "本議案は、各種手数料の納付などに用いられる埼玉県証紙に関する特別会計の予算案です。令和8年度の歳入歳出予算規模は5,120万円として計上されています。\n\n## 参照\n- [令和8年2月定例会 議案一覧 - 埼玉県議会](https://www.pref.saitama.lg.jp/e1601/gikai-gaiyou/r0802/2.html)",
      "created_at": "2026-04-28T15:32:28.646Z",
      "updated_at": "2026-04-28T16:16:44.000Z"
    }
  ],
