    {
      "id": "66014c5d-7335-4c87-8025-53dd131b2d68",
      "bill_id": "8e5a94a9-aafe-4e1a-b35d-9ed3df34d16e",
      "difficulty_level": "normal",
      "title": "県の借金を返すための予算案",
      "summary": "県が過去に借りたお金を返すための専用の予算案で、今年度は約5,404億円を返済や利子の支払いに充てる計画です。",
      "content": "埼玉県がこれまでに道路や学校を作るために借りたお金（県債）の返済や、その利子を支払うための専用の予算案です。令和8年度は、総額で約5,404億円を返済などのために割り当てています。",
      "created_at": "2026-04-28T15:32:28.646Z",
      "updated_at": "2026-04-28T16:16:44.000Z"
    },
    {
      "id": "ae2475ce-1f0c-4366-b3a7-fd02703809db",
      "bill_id": "8e5a94a9-aafe-4e1a-b35d-9ed3df34d16e",
      "difficulty_level": "hard",
      "title": "令和8年度埼玉県公債費特別会計予算",
      "summary": "県の借金である県債の返済や利子支払いを行うための「公債費特別会計」の予算案です。令和8年度の予算総額は5,404億4,786万6千円となっています。",
      "content": "本議案は、県債（県の借金）の元金や利子の支払い等を管理する公債費特別会計の令和8年度予算案です。歳入歳出予算の総額は5,404億4,786万6千円となっており、適切な債務管理と償還計画に基づいて編成されています。\n\n## 参照\n- [令和8年2月定例会 議案一覧 - 埼玉県議会](https://www.pref.saitama.lg.jp/e1601/gikai-gaiyou/r0802/2.html)",
      "created_at": "2026-04-28T15:32:28.646Z",
      "updated_at": "2026-04-28T16:16:44.000Z"
    }
  ],
