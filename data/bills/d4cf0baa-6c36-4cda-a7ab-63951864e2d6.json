  "bill_contents": [
    {
      "id": "54ceb2e9-2047-4e78-a938-05dfd4afbd78",
      "bill_id": "d4cf0baa-6c36-4cda-a7ab-63951864e2d6",
      "difficulty_level": "normal",
      "title": "国民健康保険料に子育て支援のお金を追加する条例の改正",
      "summary": "国民健康保険のルールを変える条例です。国の新しい制度に基づき、保険料に「子育て支援金」として1人あたり約3,800円を上乗せして集めることが決まりました。",
      "content": "国が新しく作った子育て支援の仕組みに合わせて、埼玉県の国民健康保険のルールを変えるものです。これにより、国民健康保険に入っている方は、保険料に加えて「子育て支援のためのお金」として1人あたり約3,800円が上乗せされることになります。生活の負担が増えるとして、一部の議員からは反対意見も出ました。",
      "created_at": "2026-04-28T15:32:28.646Z",
      "updated_at": "2026-04-28T16:16:44.000Z"
    },
    {
      "id": "97f545fc-b07b-4b26-9c40-bb73bf6d3f74",
      "bill_id": "d4cf0baa-6c36-4cda-a7ab-63951864e2d6",
      "difficulty_level": "hard",
      "title": "埼玉県国民健康保険保険給付費等交付金及び国民健康保険事業費納付金に関する条例の一部を改正する条例",
      "summary": "国の法律改正に伴い、国民健康保険税に新たに「子ども・子育て支援拠出金」を上乗せ徴収するための条例改正です。1人当たり約3,849円の実質的な負担増となるため、議会では批判や反対討論が行われました。",
      "content": "本議案は、国の「子ども・子育て支援法等の一部を改正する法律」の施行に伴い、埼玉県内の国民健康保険税に新たに「子ども・子育て支援拠出金」を上乗せして徴収するための条例改正です。これにより、被保険者1人当たり約3,849円の負担増が見込まれており、県民の医療保険料負担増につながるとして反対討論が行われました。\n\n## 参照\n- [国民健康保険税に子ども子育て支援負担金上乗せ3849円を批判 - 日本共産党埼玉県議会議員団](https://www.jcp-saitama-pref.jp/assembly-report/6423)",
      "created_at": "2026-04-28T15:32:28.646Z",
      "updated_at": "2026-04-28T16:16:44.000Z"
    }
  ],
